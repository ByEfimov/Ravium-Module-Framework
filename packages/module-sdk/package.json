{
  "name": "@ravium/module-sdk",
  "version": "1.0.2",
  "description": "Typed SDK for building Ravium modules.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByEfimov/Ravium-Module-Framework.git",
    "directory": "packages/module-sdk"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integrations/npm": {
      "types": "./dist/integrations/npm.d.ts",
      "import": "./dist/integrations/npm.js"
    },
    "./integrations/vue": {
      "types": "./dist/integrations/vue.d.ts",
      "import": "./dist/integrations/vue.js"
    },
    "./integrations/swiper": {
      "types": "./dist/integrations/swiper/index.d.ts",
      "import": "./dist/integrations/swiper/index.js"
    },
    "./integrations/swiper/vue": {
      "types": "./dist/integrations/swiper/vue.d.ts",
      "import": "./dist/integrations/swiper/vue.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "swiper": "^12.2.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "swiper": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "swiper": "^12.2.0",
    "typescript": "^5.7.2",
    "vue": "^3.5.24"
  }
}
